{
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "docsify-cli": "^4.4.4",
    "flowbite": "^3.1.2",
    "marked": "^17.0.1",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.2.0",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -i public/css/tailwind.css -o public/css/dist/tailwind.min.css --minify",
    "build:css:debug": "tailwindcss -i public/css/tailwind.css -o public/css/tailwind.output.css",
    "build:js": "webpack --config webpack.config.js",
    "clean": "rm -rf public/css/dist public/js/dist public/css/tailwind.output.css",
    "watch:css": "tailwindcss -i public/css/tailwind.css -o public/css/dist/tailwind.min.css --watch",
    "watch:js": "webpack --config webpack.config.js --watch"
  }
}
