{% autoescape false %}
    {% set createPlanUrl = relativeUrl('training-plan') %}
    {% set racePlannerUrl = relativeUrl('race-planner') %}
    {% set createNextPlanUrl = latestPlan ? (createPlanUrl ~ '?afterTrainingPlanId=' ~ latestPlan.getId()) : null %}

    <div class="space-y-6">
        {# ═══════════════════════════════════════════════════════════════════════════
           HEADER: Page title with primary actions
           ═══════════════════════════════════════════════════════════════════════════ #}
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="min-w-0">
                <h1 class="text-xl font-bold tracking-tight text-gray-900">{{ 'Plan manager'|trans }}</h1>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">{{ 'Chain training blocks, anchor races, and keep your season on track.'|trans }}</p>
            </div>
            <div class="flex flex-shrink-0 items-center gap-2">
                <a href="#" data-model-content-url="{{ createPlanUrl }}" class="inline-flex items-center gap-1.5 rounded-lg bg-strava-orange px-3.5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2">
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                    {{ 'New plan'|trans }}
                </a>
                <a href="{{ racePlannerUrl }}" data-router-navigate="{{ racePlannerUrl }}" class="inline-flex items-center gap-1.5 rounded-lg border border-gray-300 bg-white px-3.5 py-2 text-sm font-medium text-gray-700 shadow-sm transition hover:bg-gray-50">
                    <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                    {{ 'Race planner'|trans }}
                </a>
            </div>
        </div>

        {% if totalPlans == 0 %}
            {# ═══════════════════════════════════════════════════════════════════════════
               EMPTY STATE: No plans yet
               ═══════════════════════════════════════════════════════════════════════════ #}
            <div class="relative overflow-hidden rounded-xl border border-dashed border-gray-300 bg-gradient-to-br from-gray-50 to-white px-6 py-20 text-center">
                <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23000000\' fill-opacity=\'0.4\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E')"></div>
                <div class="relative">
                    <div class="mx-auto mb-5 flex size-16 items-center justify-center rounded-2xl bg-gradient-to-br from-orange-100 to-orange-50 text-strava-orange shadow-sm dark:from-orange-900/30 dark:to-orange-800/20">
                        <svg class="size-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10m-12 9h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v11a2 2 0 0 0 2 2Z"/>
                        </svg>
                    </div>
                    <h2 class="text-lg font-bold text-gray-900">{{ 'Start your season plan'|trans }}</h2>
                    <p class="mx-auto mt-2 max-w-sm text-sm text-gray-500 dark:text-gray-400">{{ 'Create your first training block or race build. Stack them together to map out the months ahead.'|trans }}</p>
                    <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
                        <a href="#" data-model-content-url="{{ createPlanUrl }}" class="inline-flex items-center gap-1.5 rounded-lg bg-strava-orange px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-orange-600">
                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                            {{ 'Create first plan'|trans }}
                        </a>
                    </div>
                </div>
            </div>
        {% else %}
            {# ═══════════════════════════════════════════════════════════════════════════
               DASHBOARD STATS: Focus plan, Continuity, Plan mix
               ═══════════════════════════════════════════════════════════════════════════ #}
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {# Focus plan card #}
                <div class="group relative overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition hover:shadow-md">
                    <div class="absolute -right-6 -top-6 size-24 rounded-full bg-gradient-to-br from-emerald-100 to-transparent opacity-50 transition-transform group-hover:scale-110 dark:from-emerald-800 dark:opacity-30"></div>
                    <div class="relative">
                        <div class="flex items-center gap-2">
                            <div class="flex size-8 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600 dark:bg-emerald-800 dark:text-emerald-300">
                                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
                            </div>
                            <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">{{ 'Focus plan'|trans }}</h3>
                        </div>
                        {% if activePlanRecord %}
                            {% set focusPlan = activePlanRecord.plan %}
                            {% set focusPlanTitle = focusPlan.getTitle() ?: (activePlanRecord.linkedRace ? (activePlanRecord.linkedRace.getTitle() ?: activePlanRecord.linkedRace.getProfile()|trans) : (focusPlan.getType().value == 'race' ? 'Race plan' : 'Training plan')) %}
                            <p class="mt-3 text-lg font-bold text-gray-900">{{ focusPlanTitle }}</p>
                            <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">{{ focusPlan.getStartDay().format('M j') }} → {{ focusPlan.getEndDay().format('M j, Y') }}</p>
                            <div class="mt-3">
                                {% if activePlanRecord.status == 'current' %}
                                    <span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700 dark:bg-emerald-800 dark:text-emerald-200">
                                        <span class="size-1.5 animate-pulse rounded-full bg-emerald-500 dark:bg-emerald-400"></span>
                                        {{ 'In progress'|trans }}
                                    </span>
                                {% elseif activePlanRecord.status == 'upcoming' %}
                                    <span class="inline-flex items-center rounded-full bg-sky-100 px-2.5 py-1 text-xs font-semibold text-sky-700 dark:bg-sky-800 dark:text-sky-200">{{ 'Next up'|trans }}</span>
                                {% else %}
                                    <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-600">{{ 'Most recent'|trans }}</span>
                                {% endif %}
                            </div>
                        {% else %}
                            <p class="mt-3 text-sm text-gray-400 dark:text-gray-500">{{ 'No active plan'|trans }}</p>
                        {% endif %}
                    </div>
                </div>

                {# Continuity card #}
                <div class="group relative overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition hover:shadow-md">
                    {% set hasIssues = continuitySummary.gapCount + continuitySummary.overlapCount > 0 %}
                    <div class="absolute -right-6 -top-6 size-24 rounded-full bg-gradient-to-br {{ hasIssues ? 'from-amber-100 dark:from-amber-800' : 'from-emerald-100 dark:from-emerald-800' }} to-transparent opacity-50 transition-transform group-hover:scale-110 dark:opacity-30"></div>
                    <div class="relative">
                        <div class="flex items-center gap-2">
                            <div class="flex size-8 items-center justify-center rounded-lg {{ hasIssues ? 'bg-amber-100 text-amber-600 dark:bg-amber-800 dark:text-amber-300' : 'bg-emerald-100 text-emerald-600 dark:bg-emerald-800 dark:text-emerald-300' }}">
                                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
                            </div>
                            <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">{{ 'Continuity'|trans }}</h3>
                        </div>
                        <p class="mt-3 text-3xl font-bold {{ hasIssues ? 'text-amber-600 dark:text-amber-400' : 'text-emerald-600 dark:text-emerald-400' }}">
                            {{ hasIssues ? (continuitySummary.gapCount + continuitySummary.overlapCount) : '✓' }}
                        </p>
                        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                            {% if not hasIssues %}
                                {{ 'No gaps or overlaps'|trans }}
                            {% else %}
                                {{ continuitySummary.gapCount }} {{ 'gaps'|trans }}, {{ continuitySummary.overlapCount }} {{ 'overlaps'|trans }}
                            {% endif %}
                        </p>
                        {% if nextSuggestedStartDay %}
                            <p class="mt-2 text-xs text-gray-400">{{ 'Next start'|trans }}: <span class="font-medium text-gray-700">{{ nextSuggestedStartDay }}</span></p>
                        {% endif %}
                    </div>
                </div>

                {# Plan mix card #}
                <div class="group relative overflow-hidden rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition hover:shadow-md sm:col-span-2 lg:col-span-1">
                    <div class="absolute -right-6 -top-6 size-24 rounded-full bg-gradient-to-br from-violet-100 to-transparent opacity-50 transition-transform group-hover:scale-110 dark:from-violet-800 dark:opacity-30"></div>
                    <div class="relative">
                        <div class="flex items-center gap-2">
                            <div class="flex size-8 items-center justify-center rounded-lg bg-violet-100 text-violet-600 dark:bg-violet-800 dark:text-violet-300">
                                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg></svg>
                            </div>
                            <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">{{ 'Plan mix'|trans }}</h3>
                        </div>
                        <div class="mt-4 flex items-baseline gap-6">
                            <div class="text-center">
                                <p class="text-2xl font-bold text-gray-900">{{ racePlanCount }}</p>
                                <p class="text-xs text-gray-500 dark:text-gray-400">{{ 'Race'|trans }}</p>
                            </div>
                            <div class="text-center">
                                <p class="text-2xl font-bold text-gray-900">{{ trainingPlanCount }}</p>
                                <p class="text-xs text-gray-500 dark:text-gray-400">{{ 'Training'|trans }}</p>
                            </div>
                            {% if unassignedUpcomingRaces|length > 0 %}
                                <div class="text-center">
                                    <p class="text-2xl font-bold text-amber-600 dark:text-amber-400">{{ unassignedUpcomingRaces|length }}</p>
                                    <p class="text-xs text-gray-500 dark:text-gray-400">{{ 'Unlinked'|trans }}</p>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        {# ═══════════════════════════════════════════════════════════════════════════
           UNLINKED RACES: Upcoming races needing a plan
           ═══════════════════════════════════════════════════════════════════════════ #}
        {% if unassignedUpcomingRaces is not empty %}
            <div class="rounded-xl border border-amber-200 bg-gradient-to-r from-amber-50 to-white p-4 dark:border-amber-800/50 dark:from-amber-900/20 dark:to-gray-900">
                <div class="flex items-start gap-3">
                    <div class="flex size-9 flex-shrink-0 items-center justify-center rounded-lg bg-amber-100 text-amber-600 dark:bg-amber-900/50 dark:text-amber-400">
                        <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
                    </div>
                    <div class="min-w-0 flex-1">
                        <h3 class="text-sm font-semibold text-amber-900 dark:text-amber-200">{{ 'Races without a plan'|trans }}</h3>
                        <div class="mt-3 flex flex-wrap gap-2">
                            {% for raceEvent in unassignedUpcomingRaces %}
                                {% set createRacePlanUrl = createPlanUrl ~ '?targetRaceEventId=' ~ raceEvent.getId() %}
                                <a href="#" data-model-content-url="{{ createRacePlanUrl }}" class="group inline-flex items-center gap-2 rounded-lg border border-amber-200 bg-white px-3 py-2 text-sm transition hover:border-amber-300 hover:bg-amber-50 dark:border-amber-700">
                                    <span class="font-medium text-gray-900">{{ raceEvent.getTitle() ?: raceEvent.getProfile()|trans }}</span>
                                    <span class="text-xs text-gray-500 dark:text-gray-400">{{ raceEvent.getDay().format('M j') }}</span>
                                    <svg class="size-4 text-gray-400 transition group-hover:text-strava-orange" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        {# ═══════════════════════════════════════════════════════════════════════════
           PLAN TIMELINE: List of all plans with visual connectors
           ═══════════════════════════════════════════════════════════════════════════ #}
        {% if totalPlans > 0 %}
            <div class="relative">
                {# Timeline connector line #}
                <div class="absolute left-[23px] top-0 hidden h-full w-0.5 bg-gradient-to-b from-gray-200 via-gray-200 to-transparent lg:block dark:from-gray-700 dark:via-gray-700"></div>

                <div class="space-y-4">
                    {% for record in planRecords %}
                        {% set plan = record.plan %}
                        {% set planTitle = plan.getTitle() ?: (record.linkedRace ? (record.linkedRace.getTitle() ?: record.linkedRace.getProfile()|trans) : (plan.getType().value == 'race' ? 'Race plan'|trans : 'Training plan'|trans)) %}
                        {% set editPlanUrl = createPlanUrl ~ '?trainingPlanId=' ~ plan.getId() %}
                        {% set createFollowUpUrl = createPlanUrl ~ '?afterTrainingPlanId=' ~ plan.getId() %}
                        {% set planRacePlannerUrl = relativeUrl(record.racePlannerPath) %}

                        {# Status-based styling #}
                        {% set isCurrent = record.status == 'current' %}
                        {% set isUpcoming = record.status == 'upcoming' %}
                        {% set isRace = plan.getType().value == 'race' %}
                        {% set accentColor = isCurrent ? 'emerald' : (isUpcoming ? 'sky' : 'gray') %}
                        {% set typeColor = isRace ? 'rose' : 'violet' %}

                        <div class="group relative flex gap-4">
                            {# Timeline node #}
                            <div class="relative z-10 hidden flex-shrink-0 lg:block">
                                <div class="flex size-12 items-center justify-center rounded-xl border-2 {{ isCurrent ? 'border-emerald-500 bg-emerald-50 dark:border-emerald-400 dark:bg-emerald-900/30' : (isUpcoming ? 'border-sky-400 bg-sky-50 dark:border-sky-500 dark:bg-sky-900/30' : 'border-gray-300 bg-gray-50') }} shadow-sm transition group-hover:shadow-md">
                                    {% if isRace %}
                                        <svg class="size-5 {{ isCurrent ? 'text-emerald-600 dark:text-emerald-400' : (isUpcoming ? 'text-sky-600 dark:text-sky-400' : 'text-gray-500 dark:text-gray-400') }}" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 002.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 012.916.52 6.003 6.003 0 01-5.395 4.972m0 0a6.726 6.726 0 01-2.749 1.35m0 0a6.772 6.772 0 01-3.044 0"/></svg>
                                    {% else %}
                                        <svg class="size-5 {{ isCurrent ? 'text-emerald-600 dark:text-emerald-400' : (isUpcoming ? 'text-sky-600 dark:text-sky-400' : 'text-gray-500 dark:text-gray-400') }}" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                                    {% endif %}
                                </div>
                            </div>

                            {# Plan card #}
                            <div class="min-w-0 flex-1 overflow-hidden rounded-xl border {{ isCurrent ? 'border-emerald-200 ring-1 ring-emerald-100 dark:border-emerald-600 dark:ring-emerald-700' : (isUpcoming ? 'border-sky-200 dark:border-sky-600' : 'border-gray-200') }} bg-white shadow-sm transition hover:shadow-md">
                                <div class="flex flex-col gap-3 p-4 lg:flex-row lg:items-start lg:justify-between lg:gap-5">
                                    {# Plan details #}
                                    <div class="min-w-0 flex-1 space-y-2">
                                        {# Header: Title + Badges + Date #}
                                        <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                                            <h3 class="text-base font-bold text-gray-900">{{ planTitle }}</h3>
                                            <div class="flex items-center gap-1.5">
                                                <span class="inline-flex items-center rounded px-1.5 py-0.5 text-[10px] font-semibold {{ isCurrent ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-800 dark:text-emerald-200' : (isUpcoming ? 'bg-sky-100 text-sky-700 dark:bg-sky-800 dark:text-sky-200' : 'bg-gray-100 text-gray-500') }}">{{ isCurrent ? 'Current'|trans : (isUpcoming ? 'Upcoming'|trans : 'Completed'|trans) }}</span>
                                                <span class="inline-flex items-center rounded px-1.5 py-0.5 text-[10px] font-semibold {{ isRace ? 'bg-rose-100 text-rose-700 dark:bg-rose-800 dark:text-rose-200' : 'bg-violet-100 text-violet-700 dark:bg-violet-800 dark:text-violet-200' }}">{{ isRace ? 'Race'|trans : 'Training'|trans }}</span>
                                            </div>
                                        </div>

                                        {# Date line #}
                                        <p class="text-sm text-gray-500 dark:text-gray-400">
                                            {{ plan.getStartDay().format('M j') }} → {{ plan.getEndDay().format('M j, Y') }}
                                            <span class="mx-1 text-gray-300 dark:text-gray-600">·</span>
                                            {{ plan.getDurationInWeeks() }}w
                                            {% if record.linkedRace %}
                                                <span class="mx-1 text-gray-300 dark:text-gray-600">·</span>
                                                {{ record.linkedRace.getDay().format('M j') }}
                                            {% endif %}
                                        </p>

                                        {# Discipline + Objective row #}
                                        {% if record.discipline or record.objective %}
                                            <div class="flex flex-wrap items-center gap-1.5">
                                                {% if record.discipline %}
                                                    <span class="rounded border border-gray-200 bg-gray-50 px-1.5 py-0.5 text-[11px] font-medium text-gray-600">{{ record.discipline|trans }}</span>
                                                {% endif %}
                                                {% if record.objective %}
                                                    <span class="rounded border border-amber-200 bg-amber-50 px-1.5 py-0.5 text-[11px] font-medium text-amber-700 dark:border-amber-500 dark:bg-amber-800 dark:text-amber-200">{{ record.objective|trans }}</span>
                                                {% endif %}
                                            </div>
                                        {% endif %}

                                        {# Combined metadata row: Schedule, Metrics, Races #}
                                        {% set windowRaces = record.windowRaces ?? [] %}
                                        {% set hasMetadata = record.scheduleHighlights is not empty or record.performanceHighlights is not empty or (windowRaces|length > 1 or (record.linkedRace is null and windowRaces is not empty)) %}
                                        {% if hasMetadata %}
                                            <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 text-[11px] text-gray-500 dark:text-gray-400">
                                                {% if record.scheduleHighlights is not empty %}
                                                    <span class="inline-flex items-center gap-1">
                                                        <span class="font-semibold text-gray-400 dark:text-gray-400">{{ 'Schedule'|trans }}</span>
                                                        {% for highlight in record.scheduleHighlights %}
                                                            <span class="rounded bg-sky-100 px-1 py-px font-medium text-sky-700 dark:bg-sky-800 dark:text-sky-200">{{ highlight }}</span>
                                                        {% endfor %}
                                                    </span>
                                                {% endif %}
                                                {% if record.performanceHighlights is not empty %}
                                                    <span class="inline-flex items-center gap-1">
                                                        <span class="font-semibold text-gray-400 dark:text-gray-400">{{ 'Metrics'|trans }}</span>
                                                        {% for highlight in record.performanceHighlights %}
                                                            <span class="rounded bg-emerald-100 px-1 py-px font-medium text-emerald-700 dark:bg-emerald-800 dark:text-emerald-200">{{ highlight }}</span>
                                                        {% endfor %}
                                                    </span>
                                                {% endif %}
                                                {% if windowRaces|length > 1 or (record.linkedRace is null and windowRaces is not empty) %}
                                                    <span class="inline-flex items-center gap-1">
                                                        <span class="font-semibold text-gray-400 dark:text-gray-400">{{ 'Races'|trans }}</span>
                                                        {% for raceEvent in windowRaces %}
                                                            {% set racePriority = raceEvent.getPriority().value %}
                                                            {% set priorityClasses = racePriority == 'a' ? 'bg-rose-100 text-rose-700 dark:bg-rose-800 dark:text-rose-200' : (racePriority == 'b' ? 'bg-amber-100 text-amber-700 dark:bg-amber-800 dark:text-amber-200' : 'bg-sky-100 text-sky-700 dark:bg-sky-800 dark:text-sky-200') %}
                                                            <span class="rounded px-1 py-px font-medium {{ priorityClasses }}">{{ racePriority|upper }} {{ raceEvent.getTitle() ?: raceEvent.getProfile()|trans }}</span>
                                                        {% endfor %}
                                                    </span>
                                                {% endif %}
                                            </div>
                                        {% endif %}

                                        {# Warnings #}
                                        {% if record.linkedRaceState == 'missing' %}
                                            <p class="flex items-center gap-1 text-xs font-medium text-red-600 dark:text-red-400">
                                                <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
                                                {{ 'Linked race no longer exists'|trans }}
                                            </p>
                                        {% endif %}
                                        {% if record.linkedRaceState == 'outside-window' and record.linkedRace %}
                                            <p class="flex items-center gap-1 text-xs font-medium text-amber-600 dark:text-amber-400">
                                                <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
                                                {{ 'Race falls outside plan window'|trans }}
                                            </p>
                                        {% endif %}

                                        {# Notes #}
                                        {% if plan.getNotes() %}
                                            <p class="text-sm leading-relaxed text-gray-600 dark:text-gray-400">{{ plan.getNotes()|nl2br }}</p>
                                        {% endif %}
                                    </div>

                                    {# Actions - icon-only buttons #}
                                    <div class="flex flex-shrink-0 items-center gap-1.5 lg:flex-col lg:gap-1">
                                        <a href="{{ planRacePlannerUrl }}" data-router-navigate="{{ planRacePlannerUrl }}" class="flex size-10 lg:size-9 items-center justify-center rounded-lg border border-gray-200 bg-white text-gray-500 transition hover:border-gray-300 hover:bg-gray-50 hover:text-gray-700" title="{{ 'Open in race planner'|trans }}">
                                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
                                        </a>
                                        <a href="#" data-model-content-url="{{ editPlanUrl }}" class="flex size-10 lg:size-9 items-center justify-center rounded-lg border border-gray-200 bg-white text-gray-500 transition hover:border-gray-300 hover:bg-gray-50 hover:text-gray-700" title="{{ 'Edit plan'|trans }}">
                                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"/></svg>
                                        </a>
                                        <a href="#" data-model-content-url="{{ createFollowUpUrl }}" class="flex size-10 lg:size-9 items-center justify-center rounded-lg border border-gray-200 bg-white text-gray-500 transition hover:border-gray-300 hover:bg-gray-50 hover:text-gray-700" title="{{ 'Create next plan'|trans }}">
                                            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
                                        </a>
                                    </div>
                                </div>

                                {# Continuity footer #}
                                {% if record.continuity %}
                                    {% set nextPlan = record.continuity.nextPlan %}
                                    {% set nextPlanTitle = nextPlan.getTitle() ?: (nextPlan.getType().value == 'race' ? 'Race plan'|trans : 'Training plan'|trans) %}
                                    <div class="border-t {{ record.continuity.kind == 'gap' ? 'border-amber-200 bg-amber-50/50 dark:border-amber-700 dark:bg-amber-900/60' : (record.continuity.kind == 'overlap' ? 'border-rose-200 bg-rose-50/50 dark:border-rose-700 dark:bg-rose-900/60' : 'border-emerald-200 bg-emerald-50/50 dark:border-emerald-700 dark:bg-emerald-900/60') }} px-4 py-2 lg:px-5">
                                        <p class="flex items-center gap-1.5 text-xs">
                                            {% if record.continuity.kind == 'gap' %}
                                                <svg class="size-3.5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z"/></svg>
                                                <span class="font-medium text-amber-700 dark:text-amber-300">{{ '{days, plural, one {Gap of # day} other {Gap of # days}}'|trans({'%days%': record.continuity.days}) }}</span>
                                                <span class="text-gray-500 dark:text-gray-400">{{ 'before'|trans }} {{ nextPlanTitle }}</span>
                                            {% elseif record.continuity.kind == 'overlap' %}
                                                <svg class="size-3.5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
                                                <span class="font-medium text-rose-700 dark:text-rose-300">{{ '{days, plural, one {Overlap of # day} other {Overlap of # days}}'|trans({'%days%': record.continuity.days}) }}</span>
                                                <span class="text-gray-500 dark:text-gray-400">{{ 'with'|trans }} {{ nextPlanTitle }}</span>
                                            {% else %}
                                                <svg class="size-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                                                <span class="font-medium text-emerald-700 dark:text-emerald-300">{{ 'Perfect handoff'|trans }}</span>
                                                <span class="text-gray-500 dark:text-gray-400">→ {{ nextPlanTitle }}</span>
                                            {% endif %}
                                        </p>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endif %}
    </div>
{% endautoescape %}
