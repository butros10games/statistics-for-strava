{% autoescape false %}
    <div class="modal-header flex items-center justify-between">
        <h3>
            <span>{{ "Morning recovery check-in"|trans }}</span>
        </h3>
        <div class="flex items-center">
            <button type="button" class="close">
                <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                </svg>
                <span class="sr-only">{{ "Close modal"|trans }}</span>
            </button>
        </div>
    </div>
    <div class="modal-body space-y-4">
        {% if latestRecoveryCheckIn %}
            <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-700">
                {{ "Today's check-in already exists. Adjust it here if your recovery status changed."|trans }}
            </div>
        {% else %}
            <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-700">
                {{ "No check-in recorded for today yet. Fill this in to improve readiness and daily load interpretation."|trans }}
            </div>
        {% endif %}

        {% include 'html/dashboard/recovery-check-in-form.html.twig' with {
            'context': 'modal',
            'latestRecoveryCheckInOverall': latestRecoveryCheckInOverall,
            'recoveryCheckInDefaultDay': recoveryCheckInDefaultDay,
            'recoveryCheckInFormDefaults': recoveryCheckInFormDefaults,
            'redirectTo': redirectTo|default('/dashboard')
        } %}
    </div>
{% endautoescape %}