{# ═══════════════════════════════════════════════════════ #}
{# Training Load Analysis — dashboard widget metrics     #}
{# ═══════════════════════════════════════════════════════ #}

{% set currentTsb = trainingMetrics.getCurrentTsb() %}
{% set currentAcRatio = trainingMetrics.getCurrentAcRatio() %}
{% set currentMonotony = trainingMetrics.getCurrentMonotony() %}
{% set tsbColor = currentTsb.getStatus().getTextColor() %}
{% set acColor = currentAcRatio.getStatus().getTextColor() %}
{% set monotonyColor = currentMonotony > 2.0 ? 'text-red-600' : (currentMonotony > 1.5 ? 'text-yellow-600' : 'text-green-600') %}
{% set cardClass = 'rounded-lg border border-gray-200 bg-gray-100 p-4 shadow-xs' %}
{% set statusCardClass = cardClass ~ ' border-l-4' %}
{% set labelClass = 'text-[11px] font-medium text-gray-500 uppercase tracking-wide' %}

<div class="space-y-4">
    {# ═══ HERO ROW: Readiness Gauge + Key Metrics ═══ #}
    <div class="flex flex-col lg:flex-row gap-4">

        {# ── Readiness Gauge ── #}
        {% if readinessScore %}
        {% set readinessColor = readinessScore.getStatus().getTextColor() %}
        {% set readinessValue = readinessScore.getValue() %}
        {% set topPositiveReadinessFactors = readinessAssessment ? readinessAssessment.getTopPositiveFactors(2) : [] %}
        {% set topNegativeReadinessFactors = readinessAssessment ? readinessAssessment.getTopNegativeFactors(2) : [] %}
        <div class="shrink-0 flex flex-col items-center rounded-xl border border-gray-200 bg-gray-100 px-4 py-4 shadow-xs lg:w-64"
             style="animation: metric-fade-in 0.5s ease-out backwards">
            {# SVG Arc Gauge — 260° arc with 100° bottom gap #}
            {% set arcLength = 204 %}
            {% set circumference = 283 %}
            {% set progressFill = ((arcLength * readinessValue) / 100)|round(1) %}
            <div class="relative w-28 h-28">
                <svg class="w-full h-full" viewBox="0 0 100 100" style="transform: rotate(-130deg)">
                    {# Track — fixed color to avoid dark mode inversion #}
                    <circle cx="50" cy="50" r="45" fill="none"
                        stroke="rgba(150,150,150,0.18)"
                        stroke-width="6" stroke-dasharray="{{ arcLength }} {{ circumference }}" stroke-linecap="round"/>
                    {# Progress #}
                    <circle cx="50" cy="50" r="45" fill="none" stroke="currentColor" class="{{ readinessColor }}"
                        stroke-width="6.5" stroke-linecap="round"
                        style="stroke-dasharray: {{ progressFill }} {{ circumference }}; animation: gauge-fill 1s ease-out"/>
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <span class="text-3xl font-black {{ readinessColor }}" style="line-height: 1">{{ readinessValue|formatNumber(0) }}</span>
                    <span class="text-[10px] text-gray-500 mt-1">/100</span>
                </div>
            </div>

            <div class="flex items-center gap-1.5 mt-3">
                <span class="{{ labelClass }}">{{ "Readiness"|trans }}</span>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-semibold {{ readinessColor }} bg-gray-200">{{ readinessScore.getStatus()|trans }}</span>
                <button class="hidden lg:block" data-popover-target="popover-readiness-{{ context }}" data-popover-placement="right" type="button">
                    <svg class="w-3.5 h-3.5 text-gray-400 hover:text-gray-500" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>
                </button>
                <div data-popover id="popover-readiness-{{ context }}" role="tooltip" class="hidden lg:block max-w-100 text-xs">
                    <div class="p-2 space-y-2">
                        <p>{{ "A research-informed readiness score that blends load balance, monotony, individualized HRV/sleep baselines, and your latest morning recovery check-in."|trans }}</p>
                        <ul class="space-y-2">
                            {% for readinessStatus in enum('App\\Domain\\Dashboard\\Widget\\TrainingLoad\\ReadinessStatus').cases() %}
                                <li><span class="{{ readinessStatus.getTextColor() }} font-semibold">{{ readinessStatus.getRange() }}</span>: {{ readinessStatus|trans }} - {{ readinessStatus|transDescription }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            </div>

            <div class="flex flex-wrap justify-center gap-x-3 gap-y-0.5 text-[11px] text-gray-500 mt-2.5">
                {% if latestWellnessHrv is not null %}
                    <span>{{ "HRV"|trans }} {{ latestWellnessHrv|formatNumber(1) }}{% if wellnessHrvBaseline is not null %} / {{ wellnessHrvBaseline|formatNumber(1) }}{% endif %} ms</span>
                {% endif %}
                {% if latestWellnessSleepScore is not null %}
                    <span>{{ "Sleep"|trans }} {{ latestWellnessSleepScore }}</span>
                {% endif %}
                {% if latestRecoveryCheckIn %}
                    <span>{{ "Fatigue"|trans }} {{ latestRecoveryCheckIn.fatigue }}/5</span>
                {% endif %}
            </div>

            {% if topPositiveReadinessFactors or topNegativeReadinessFactors %}
                <div class="flex flex-wrap justify-center gap-1.5 mt-3">
                    {% for factor in topPositiveReadinessFactors %}
                        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium bg-green-100 text-green-800">{{ factor.getLabel()|trans }} +{{ factor.getValue()|formatNumber(0) }}</span>
                    {% endfor %}
                    {% for factor in topNegativeReadinessFactors %}
                        <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[10px] font-medium bg-amber-100 text-amber-900">{{ factor.getLabel()|trans }} {{ factor.getValue()|formatNumber(0) }}</span>
                    {% endfor %}
                </div>
            {% endif %}
        </div>
        {% endif %}

        {# ── Metrics Grid ── #}
        <div class="flex-1 grid grid-cols-2 lg:grid-cols-4 gap-3">
            {# Row 1: CTL, ATL, TSB, A:C #}
            <div class="{{ cardClass }}" style="animation: metric-fade-in 0.4s ease-out 0.05s backwards">
                <div class="flex items-center gap-1 mb-2">
                    <h4 class="{{ labelClass }}">{{ "CTL"|trans }}</h4>
                    <button class="hidden lg:block" data-popover-target="popover-ctl-{{ context }}" data-popover-placement="right" type="button">
                        <svg class="w-3.5 h-3.5 text-gray-400 hover:text-gray-500" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>
                    </button>
                    <div data-popover id="popover-ctl-{{ context }}" role="tooltip" class="hidden lg:block max-w-100 text-xs">
                        <div class="p-2 space-y-2">
                            <p>{{ "Chronic Training Load (Fitness) - 42-day exponentially weighted average of your daily training load. Represents long-term training adaptation."|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="text-2xl font-bold">{{ trainingMetrics.getCurrentCtl()|formatNumber(1) }}</div>
                <div class="text-xs text-gray-500 mt-1">{{ "Fitness"|trans }}</div>
            </div>

            <div class="{{ cardClass }}" style="animation: metric-fade-in 0.4s ease-out 0.1s backwards">
                <div class="flex items-center gap-1 mb-2">
                    <h4 class="{{ labelClass }}">{{ "ATL"|trans }}</h4>
                    <button class="hidden lg:block" data-popover-target="popover-atl-{{ context }}" data-popover-placement="right" type="button">
                        <svg class="w-3.5 h-3.5 text-gray-400 hover:text-gray-500" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>
                    </button>
                    <div data-popover id="popover-atl-{{ context }}" role="tooltip" class="hidden lg:block max-w-100 text-xs">
                        <div class="p-2 space-y-2">
                            <p>{{ "Acute Training Load (Fatigue) - 7-day exponentially weighted average of your daily training load. Represents short-term fatigue."|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="text-2xl font-bold">{{ trainingMetrics.getCurrentAtl()|formatNumber(1) }}</div>
                <div class="text-xs text-gray-500 mt-1">{{ "Fatigue"|trans }}</div>
            </div>

            <div class="{{ statusCardClass }} {{ tsbColor|replace({'text-': 'border-l-'}) }}" style="animation: metric-fade-in 0.4s ease-out 0.15s backwards">
                <div class="flex items-center gap-1 mb-2">
                    <h4 class="{{ labelClass }}">{{ "TSB"|trans }}</h4>
                    <button class="hidden lg:block" data-popover-target="popover-tsb-{{ context }}" data-popover-placement="right" type="button">
                        <svg class="w-3.5 h-3.5 text-gray-400 hover:text-gray-500" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>
                    </button>
                    <div data-popover id="popover-tsb-{{ context }}" role="tooltip" class="hidden lg:block max-w-100 text-xs">
                        <div class="p-2 space-y-2">
                            <p>{{ "Training Stress Balance (Form) – The difference between fitness (CTL) and fatigue (ATL). Reflects how ready you are to perform."|trans }}</p>
                            <ul class="space-y-2">
                                {% for tsbStatus in enum('App\\Domain\\Dashboard\\Widget\\TrainingLoad\\TSBStatus').cases() %}
                                    <li><span class="{{ tsbStatus.getTextColor() }} font-semibold">{{ tsbStatus.getRange() }}</span>: {{ tsbStatus|trans }} - {{ tsbStatus|transDescription }}</li>
                                {% endfor %}
                            </ul>
                            <p class="text-xs italic mt-2">{{ "Guidelines vary by individual; for more information see Joe Friel's 'The Cyclist's Training Bible' or TrainingPeaks' research documentation."|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="text-2xl font-bold {{ tsbColor }}">{{ currentTsb.getValue()|formatNumber(1) }}</div>
                <div class="text-xs text-gray-500 mt-1">{{ currentTsb.getStatus()|trans }}</div>
            </div>

            <div class="{{ statusCardClass }} {{ acColor|replace({'text-': 'border-l-'}) }}" style="animation: metric-fade-in 0.4s ease-out 0.2s backwards">
                <div class="flex items-center gap-1 mb-2">
                    <h4 class="{{ labelClass }}">{{ "A:C"|trans }}</h4>
                    <button class="hidden lg:block" data-popover-target="popover-ac-{{ context }}" data-popover-placement="right" type="button">
                        <svg class="w-3.5 h-3.5 text-gray-400 hover:text-gray-500" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>
                    </button>
                    <div data-popover id="popover-ac-{{ context }}" role="tooltip" class="hidden lg:block max-w-100 text-xs">
                        <div class="p-2 space-y-2">
                            <p>{{ "Acute:Chronic Ratio - Ratio of ATL to CTL. Indicates injury risk."|trans }}</p>
                            <ul class="space-y-2">
                                {% for acRatioStatus in enum('App\\Domain\\Dashboard\\Widget\\TrainingLoad\\AcRatioStatus').cases() %}
                                    <li><span class="{{ acRatioStatus.getTextColor() }} font-semibold">{{ acRatioStatus.getRange() }}</span>: {{ acRatioStatus|trans }} - {{ acRatioStatus|transDescription }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="text-2xl font-bold {{ acColor }}">{{ currentAcRatio.getValue()|formatNumber(2) }}</div>
                <div class="text-xs text-gray-500 mt-1">{{ currentAcRatio.getStatus()|trans }}</div>
            </div>

            {# Row 2: Monotony, Rest, Strain, Load #}
            <div class="{{ statusCardClass }} {{ monotonyColor|replace({'text-': 'border-l-'}) }}" style="animation: metric-fade-in 0.4s ease-out 0.25s backwards">
                <div class="flex items-center gap-1 mb-2">
                    <h4 class="{{ labelClass }}">{{ "Monotony"|trans }}</h4>
                    <button class="hidden lg:block" data-popover-target="popover-monotony-{{ context }}" data-popover-placement="right" type="button">
                        <svg class="w-3.5 h-3.5 text-gray-400 hover:text-gray-500" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>
                    </button>
                    <div data-popover id="popover-monotony-{{ context }}" role="tooltip" class="hidden lg:block max-w-100 text-xs">
                        <div class="p-2 space-y-2">
                            <p>{{ "Training Monotony - Ratio of average daily load to standard deviation. Indicates training variety."|trans }}</p>
                            <p>{{ "< 1.5: Good variety in training"|trans }}</p>
                            <p>{{ "> 2.0: High monotony, increased risk"|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="text-2xl font-bold {{ monotonyColor }}">{{ currentMonotony|formatNumber(2) }}</div>
                <div class="text-xs text-gray-500 mt-1">
                    {% if currentMonotony > 2.0 %}
                        {{ "High monotony"|trans }}
                    {% elseif currentMonotony > 1.5 %}
                        {{ "Moderate"|trans }}
                    {% else %}
                        {{ "Good variety"|trans }}
                    {% endif %}
                </div>
            </div>

            <div class="{{ cardClass }}" style="animation: metric-fade-in 0.4s ease-out 0.3s backwards">
                <div class="flex items-center gap-1 mb-2">
                    <h4 class="{{ labelClass }}">{{ "Rest"|trans }}</h4>
                </div>
                <div class="text-2xl font-bold">{{ restDaysInLast7Days }}<span class="text-sm font-normal text-gray-500">/7</span></div>
                <div class="text-xs text-gray-500 mt-1">{{ "Last 7 days"|trans }}</div>
            </div>

            <div class="{{ cardClass }}" style="animation: metric-fade-in 0.4s ease-out 0.35s backwards">
                <div class="flex items-center gap-1 mb-2">
                    <h4 class="{{ labelClass }}">{{ "Strain"|trans }}</h4>
                    <button class="hidden lg:block" data-popover-target="popover-strain-{{ context }}" data-popover-placement="right" type="button">
                        <svg class="w-3.5 h-3.5 text-gray-400 hover:text-gray-500" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>
                    </button>
                    <div data-popover id="popover-strain-{{ context }}" role="tooltip" class="hidden lg:block max-w-100 text-xs">
                        <div class="p-2 space-y-2">
                            <p>{{ "Weekly Strain - Product of weekly training load and monotony. Overall training stress."|trans }}</p>
                            <p>{{ "Individual thresholds vary based on fitness level."|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="text-2xl font-bold">{{ trainingMetrics.getCurrentStrain() }}</div>
                <div class="text-xs text-gray-500 mt-1">{{ "Weekly"|trans }}</div>
            </div>

            <div class="{{ cardClass }}" style="animation: metric-fade-in 0.4s ease-out 0.4s backwards">
                <div class="flex items-center gap-1 mb-2">
                    <h4 class="{{ labelClass }}">{{ "Load"|trans }}</h4>
                    <button class="hidden lg:block" data-popover-target="popover-trimp-{{ context }}" data-popover-placement="right" type="button">
                        <svg class="w-3.5 h-3.5 text-gray-400 hover:text-gray-500" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>
                    </button>
                    <div data-popover id="popover-trimp-{{ context }}" role="tooltip" class="hidden lg:block max-w-100 text-xs">
                        <div class="p-2 space-y-2">
                            <p>{{ "Integrated weekly load - Banister-style activity load plus wellness-derived recovery strain from HRV, sleep, sleep score, and steps."|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="text-2xl font-bold">{{ trainingMetrics.getWeeklyTrimp() }}</div>
                <div class="text-xs text-gray-500 mt-1">{{ "7-day"|trans }}</div>
            </div>
        </div>
    </div>

    {# ═══ RECOVERY WARNINGS ═══ #}
    {% if recoveryTrendWarnings is defined and recoveryTrendWarnings|length > 0 %}
    <div class="space-y-1.5" style="animation: metric-fade-in 0.4s ease-out 0.45s backwards">
        {% for warning in recoveryTrendWarnings %}
        <div class="flex items-center gap-3 rounded-lg bg-gray-100 border border-gray-200 px-4 py-2.5">
            <span class="inline-flex items-center shrink-0 px-2 py-0.5 rounded text-[10px] font-semibold {{ warning.getPillColors() }}">
                {{ warning.getLabel()|trans }}
            </span>
            <span class="text-xs text-gray-600">{{ warning.getDescription()|trans }}</span>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    {# ═══ POLARISED TRAINING ═══ #}
    {% if timeInHeartRateZonesForLast30Days %}
    {% set percentageInLowZones = timeInHeartRateZonesForLast30Days.getPercentageInLowZones() %}
    {% set percentageInMediumZones = timeInHeartRateZonesForLast30Days.getPercentageInMediumZone() %}
    {% set percentageInHighZones = timeInHeartRateZonesForLast30Days.getPercentageInHighZones() %}
    <div class="rounded-lg border border-gray-200 bg-gray-100 p-4 shadow-xs"
         style="animation: metric-fade-in 0.4s ease-out 0.5s backwards">
        <div class="flex items-center gap-1.5 mb-3.5">
            <h4 class="{{ labelClass }}">{{ "Polarised training (30d)"|trans }}</h4>
            <button class="hidden lg:block" data-popover-target="popover-polarised-{{ context }}" data-popover-placement="right" type="button">
                <svg class="w-3.5 h-3.5 text-gray-400 hover:text-gray-500" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>
            </button>
            <div data-popover id="popover-polarised-{{ context }}" role="tooltip" class="hidden lg:block max-w-100 text-xs">
                <div class="p-2 space-y-2">
                    <p>{{ "Heart rate zone distribution over the past month. For effective polarized training, your workouts should primarily fall within the following zones"|trans }}:</p>
                    <p>{{ "Z1-2 (Low)"|trans }}: 75 - 90%</p>
                    <p>{{ "Z3 (Mod)"|trans }}: 0 - 10%</p>
                    <p>{{ "Z4-5 (High)"|trans }}: 10 - 20%</p>
                </div>
            </div>
        </div>
        <div class="overflow-hidden rounded-full bg-gray-200 h-2.5">
            <div class="flex h-full w-full overflow-hidden rounded-full">
                <div class="h-full" style="width: {{ percentageInLowZones }}%; background-color: #059669;"></div>
                <div class="h-full" style="width: {{ percentageInMediumZones }}%; background-color: #FBBF24;"></div>
                <div class="h-full" style="width: {{ percentageInHighZones }}%; background-color: #EF4444;"></div>
            </div>
        </div>
        <div class="flex flex-wrap gap-x-5 gap-y-1.5 mt-3">
            <div class="flex items-center gap-1.5">
                <span class="inline-block w-2 h-2 rounded-full shrink-0" style="background-color: #059669;"></span>
                <span class="text-xs text-gray-500"><span class="font-medium text-gray-700">{{ percentageInLowZones|formatNumber(1) }}%</span> {{ "Z1-2"|trans }}</span>
            </div>
            <div class="flex items-center gap-1.5">
                <span class="inline-block w-2 h-2 rounded-full shrink-0" style="background-color: #FBBF24;"></span>
                <span class="text-xs text-gray-500"><span class="font-medium text-gray-700">{{ percentageInMediumZones|formatNumber(1) }}%</span> {{ "Z3"|trans }}</span>
            </div>
            <div class="flex items-center gap-1.5">
                <span class="inline-block w-2 h-2 rounded-full shrink-0" style="background-color: #EF4444;"></span>
                <span class="text-xs text-gray-500"><span class="font-medium text-gray-700">{{ percentageInHighZones|formatNumber(1) }}%</span> {{ "Z4-5"|trans }}</span>
            </div>
        </div>
    </div>
    {% endif %}
</div>
