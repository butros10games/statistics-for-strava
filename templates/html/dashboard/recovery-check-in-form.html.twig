{% set uniqueId = uniqueNumberForId('recoveryCheckIn' ~ context) %}
{% set fivePointScale = [1, 2, 3, 4, 5] %}
<div class="rounded-lg border border-gray-200 bg-white p-4 shadow-xs">
    <div class="flex flex-col gap-4">
        <div>
            <div class="text-sm font-medium text-gray-900">{{ "Morning recovery check-in"|trans }}</div>
            <div class="text-xs text-gray-500 mt-1">{{ "A quick self-report helps the app balance objective Garmin data with how recovered you actually feel."|trans }}</div>
            {% if latestRecoveryCheckInOverall %}
                <div class="text-xs text-gray-600 mt-2">
                    {{ "Latest"|trans }}: {{ latestRecoveryCheckInOverall.day }} ·
                    {{ "Fatigue"|trans }} {{ latestRecoveryCheckInOverall.fatigue }}/5 ·
                    {{ "Soreness"|trans }} {{ latestRecoveryCheckInOverall.soreness }}/5 ·
                    {{ "Stress"|trans }} {{ latestRecoveryCheckInOverall.stress }}/5 ·
                    {{ "Motivation"|trans }} {{ latestRecoveryCheckInOverall.motivation }}/5 ·
                    {{ "Sleep quality"|trans }} {{ latestRecoveryCheckInOverall.sleepQuality }}/5
                </div>
            {% endif %}
        </div>
        <form action="/recovery-check-in" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1" for="recovery-check-in-day-{{ uniqueId }}">{{ "Day"|trans }}</label>
                <input id="recovery-check-in-day-{{ uniqueId }}" name="day" type="date" value="{{ recoveryCheckInDefaultDay }}" class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-amber-500 focus:ring-amber-500" />
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1" for="recovery-check-in-fatigue-{{ uniqueId }}">{{ "Fatigue"|trans }}</label>
                <select id="recovery-check-in-fatigue-{{ uniqueId }}" name="fatigue" class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-amber-500 focus:ring-amber-500">
                    {% for value in fivePointScale %}
                        <option value="{{ value }}"{% if recoveryCheckInFormDefaults.fatigue == value %} selected{% endif %}>{{ value }} / 5</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1" for="recovery-check-in-soreness-{{ uniqueId }}">{{ "Soreness"|trans }}</label>
                <select id="recovery-check-in-soreness-{{ uniqueId }}" name="soreness" class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-amber-500 focus:ring-amber-500">
                    {% for value in fivePointScale %}
                        <option value="{{ value }}"{% if recoveryCheckInFormDefaults.soreness == value %} selected{% endif %}>{{ value }} / 5</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1" for="recovery-check-in-stress-{{ uniqueId }}">{{ "Stress"|trans }}</label>
                <select id="recovery-check-in-stress-{{ uniqueId }}" name="stress" class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-amber-500 focus:ring-amber-500">
                    {% for value in fivePointScale %}
                        <option value="{{ value }}"{% if recoveryCheckInFormDefaults.stress == value %} selected{% endif %}>{{ value }} / 5</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1" for="recovery-check-in-motivation-{{ uniqueId }}">{{ "Motivation"|trans }}</label>
                <select id="recovery-check-in-motivation-{{ uniqueId }}" name="motivation" class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-amber-500 focus:ring-amber-500">
                    {% for value in fivePointScale %}
                        <option value="{{ value }}"{% if recoveryCheckInFormDefaults.motivation == value %} selected{% endif %}>{{ value }} / 5</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-700 mb-1" for="recovery-check-in-sleep-quality-{{ uniqueId }}">{{ "Sleep quality"|trans }}</label>
                <select id="recovery-check-in-sleep-quality-{{ uniqueId }}" name="sleepQuality" class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-amber-500 focus:ring-amber-500">
                    {% for value in fivePointScale %}
                        <option value="{{ value }}"{% if recoveryCheckInFormDefaults.sleepQuality == value %} selected{% endif %}>{{ value }} / 5</option>
                    {% endfor %}
                </select>
            </div>
            <div class="md:col-span-2 flex flex-col md:flex-row md:items-end md:justify-between gap-3">
                <div class="text-xs text-gray-600">{{ "Use 1 = very low/poor and 5 = very high/good. Higher fatigue, soreness, and stress reduce readiness."|trans }}</div>
                <button type="submit" class="inline-flex items-center rounded-lg bg-amber-600 px-3 py-2 text-sm font-medium text-white hover:bg-amber-700">{{ "Save check-in"|trans }}</button>
            </div>
        </form>
    </div>
</div>