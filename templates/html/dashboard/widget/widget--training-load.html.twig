{% autoescape false %}
    <div class="flex items-center justify-between gap-3 mb-5">
        <h3 class="text-lg font-semibold">{{ "Training Load Analysis"|trans }}</h3>
        <div class="flex items-center gap-2">
            <a href="{{ relativeUrl('api/exports/training-advisor.json') }}" download="training-advisor.json"
               class="shrink-0 inline-flex items-center gap-2 rounded-lg border border-blue-200 px-3 py-2 text-sm font-medium text-blue-700 hover:bg-blue-50">
                {{ "Export for AI feedback"|trans }}
            </a>
            <a href="#" data-model-content-url="{{ relativeUrl('training-load.html') }}"
               class="shrink-0 inline-flex items-center p-2 text-sm font-medium rounded-lg text-blue-600 hover:bg-gray-100">
                {{ "View details"|trans }}
            </a>
        </div>
    </div>
    {% include 'html/dashboard/training-metrics.html.twig' with {
        'trainingMetrics': trainingMetrics,
        'timeInHeartRateZonesForLast30Days': timeInHeartRateZonesForLast30Days,
        'context': 'page'
    } %}
    <div class="mt-4">
        {% include 'html/dashboard/recovery-check-in-summary.html.twig' with {
            'context': 'page',
            'latestRecoveryCheckIn': latestRecoveryCheckIn,
            'latestRecoveryCheckInOverall': latestRecoveryCheckInOverall,
            'shouldAutoOpenRecoveryCheckIn': shouldPromptRecoveryCheckIn
        } %}
    </div>
{% endautoescape %}