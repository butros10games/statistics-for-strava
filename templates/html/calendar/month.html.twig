
{% autoescape false %}
    {% set plannedSessionCount = plannedSessionsForMonth|length %}
    {% set linkedPlannedSessionCount = plannedSessionsForMonth|filter(session => session.getLinkStatus().value == 'linked')|length %}
    {% set monthlyStatsRoute = relativeUrl('monthly-stats') %}
    {% set currentMonthModalUrl = relativeUrl('month/month-' ~ calendar.getMonth().getId() ~ '.html') %}
    {% set monthRedirectTarget = monthlyStatsRoute ~ '#' ~ currentMonthModalUrl %}
    {% set estimatedPlannedLoad = 0 %}
    {% for plannedSession in plannedSessionsForMonth %}
        {% set estimatedPlannedLoad = estimatedPlannedLoad + (plannedSessionEstimatesById[plannedSession.getId() ~ ''] ?? 0) %}
    {% endfor %}
    <!-- Modal header -->
    <div class="modal-header flex items-center justify-between">
        <h3>
            {% set previousMonth = calendar.getMonth().getPreviousMonth() %}
            {% set nextMonth = calendar.getMonth().getNextMonth() %}
            {% if hasPreviousMonth %}
                <a  href="#" data-model-content-url="{{ relativeUrl('month/month-' ~ previousMonth.getId() ~ '.html') }}">
                    <svg class="w-3 h-3 text-gray-800" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 8 14">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 1 1.3 6.326a.91.91 0 0 0 0 1.348L7 13"/>
                    </svg>
                </a>
            {% endif %}
            <span class="mx-2">{{ calendar.getMonth().getLabel() }}</span>
            {% if hasNextMonth %}
                <a  href="#" data-model-content-url="{{ relativeUrl('month/month-' ~ nextMonth.getId() ~ '.html') }}">
                    <svg class="w-3 h-3 text-gray-800" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 8 14">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 13 5.7-5.326a.909.909 0 0 0 0-1.348L1 1"/>
                    </svg>
                </a>
            {% endif %}
        </h3>
        <div class="flex items-center">
            <ul class="hidden md:flex text-center mr-2 divide-x divide-gray-200">
                <li class="flex items-center gap-x-0.5 pr-2">
                    {{ svg('distance', 'size-5') }}
                    {% if statistics.distance %}
                        <div>{{ statistics.distance|convertMeasurement.toFloat()|formatNumber(0) }}</div>
                        <div class="text-xs text-gray-500">{{ statistics.distance|convertMeasurement.getSymbol() }}</div>
                    {% else %}
                        0
                    {% endif %}
                </li>
                <li class="flex items-center gap-x-0.5 px-2">
                    {{ svg('elevation', 'size-5') }}
                    {% if statistics.elevation %}
                        <div>{{ statistics.elevation|convertMeasurement.toFloat()|formatNumber(0) }}</div>
                        <div class="text-xs text-gray-500">{{ statistics.elevation|convertMeasurement.getSymbol() }}</div>
                    {% else %}
                        0
                    {% endif %}
                </li>
                <li class="flex items-center gap-x-0.5 px-2">
                    {{ svg('time', 'size-5') }}
                    <div>{{ (statistics.movingTime.toHour().toFloat())|formatNumber(0) }}</div>
                    <div class="text-xs text-gray-500">{{ "hours"|trans }}</div>
                </li>
                <li class="flex items-center gap-x-0.5 px-2">
                    {{ svg('challenge', 'size-5') }}
                    <div>{{ challenges|filter(challenge => challenge.getCreatedOn().format('Y-m') == calendar.getMonth().getId())|length }}</div>
                </li>
                <li class="flex items-center gap-x-0.5 px-2">
                    {{ svg('calories', 'size-5') }}
                    <div>{{ statistics.calories|formatNumber(0) }}</div>
                    <div class="text-xs text-gray-500">kcal</div>
                </li>
                <li class="flex items-center gap-x-0.5 pl-2">
                    {{ svg('hashtag') }}
                    <div>{{ statistics.numberOfActivities }}</div>
                    <div class="text-xs text-gray-500">{{ "workouts"|trans }}</div>
                </li>
                <li class="flex items-center gap-x-0.5 pl-2">
                    {{ svg('calendar') }}
                    <div>{{ plannedSessionCount }}</div>
                    <div class="text-xs text-gray-500">{{ "Planned sessions"|trans }}</div>
                </li>
            </ul>
            <button type="button" class="close">
                <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
                </svg>
                <span class="sr-only">{{ "Close modal"|trans }}</span>
            </button>
        </div>
    </div>
    <!-- Modal body -->
    <div class="modal-body space-y-4">
        <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-xs">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div>
                    <div class="text-sm font-semibold text-gray-800">{{ "Training planner"|trans }}</div>
                    <p class="mt-1 text-sm text-gray-600">{{ "Plan sessions directly inside the training calendar and keep them linked with completed activities automatically."|trans }}</p>
                    <div class="mt-3 flex flex-wrap gap-2 text-xs text-gray-700">
                        <span class="badge-pill">{{ plannedSessionCount }} {{ "Planned sessions"|trans }}</span>
                        <span class="badge-pill">{{ linkedPlannedSessionCount }} {{ "Auto-linked"|trans }}</span>
                        <span class="badge-pill">{{ estimatedPlannedLoad|formatNumber(0) }} {{ "Total planned load"|trans }}</span>
                    </div>
                </div>
                <div class="flex flex-wrap gap-2">
                    <a href="#" data-model-content-url="/planned-session?day={{ calendar.getMonth().getId() }}-01" class="inline-flex items-center rounded-lg bg-strava-orange px-3 py-2 text-sm font-medium text-white hover:bg-orange-600 focus:ring-4 focus:outline-hidden focus:ring-orange-300">
                        {{ "Create session"|trans }}
                    </a>
                </div>
            </div>
        </div>
        <div class="grid grid-cols-1 gap-4 xl:grid-cols-[minmax(0,1fr)_20rem]">
            <div class="flex flex-col">
                <div class="grid grid-cols-7 gap-px leading-6 font-semibold text-xs text-center border border-b-0">
                    <div class="py-2 bg-white">
                        {{ "Mon"|trans }}
                    </div>
                    <div class="py-2 bg-white">
                        {{ "Tue"|trans }}
                    </div>
                    <div class="py-2 bg-white">
                        {{ "Wed"|trans }}
                    </div>
                    <div class="py-2 bg-white">
                        {{ "Thu"|trans }}
                    </div>
                    <div class="py-2 bg-white">
                        {{ "Fri"|trans }}
                    </div>
                    <div class="py-2 bg-white">
                        {{ "Sat"|trans }}
                    </div>
                    <div class="py-2 bg-white">
                        {{ "Sun"|trans }}
                    </div>
                </div>
                <div class="grid grid-cols-7 gap-px leading-6 text-xs w-full bg-gray-200 border">
                    {#
                    class="bg-emerald-600/10 border-l-emerald-600"
                    class="bg-orange-500/10 border-l-orange-500"
                    class="bg-yellow-300/10 border-l-yellow-300"
                    class="bg-blue-600/10 border-l-blue-600"
                    class="bg-red-600/10 border-l-red-600"
                    class="bg-gray-600/10 border-l-gray-600"
                    #}
                    {% for day in calendar.getDays() %}
                        <div class="py-2 px-3 {{ day.isCurrentMonth ? 'bg-white' : 'bg-gray-100' }}">
                            <div class="flex items-center justify-between gap-2">
                                <div class="text-right text-gray-400">
                                    {{ day.getDayNumber() }}
                                </div>
                                {% if day.isCurrentMonth %}
                                    <a href="#" data-model-content-url="/planned-session?day={{ day.getDate().format('Y-m-d') }}" class="inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-semibold text-strava-orange hover:bg-gray-200">
                                        + {{ "Session"|trans }}
                                    </a>
                                {% endif %}
                            </div>
                            <div class="mt-2 h-28 overflow-y-auto space-y-2">
                                {% if day.getPlannedSessions() is not empty %}
                                    <ul class="space-y-1">
                                        {% for plannedSession in day.getPlannedSessions() %}
                                            {% set plannedColor = plannedSession.getActivityType().getColor() %}
                                            {% set plannedEstimate = plannedSessionEstimatesById[plannedSession.getId() ~ ''] ?? null %}
                                            {% set plannedTitle = plannedSession.getTitle() ?: (plannedSession.getActivityType()|trans) %}
                                            {% set linkStatusClasses = plannedSession.getLinkStatus().value == 'linked'
                                                ? 'bg-green-50 text-green-700 ring-green-200'
                                                : (plannedSession.getLinkStatus().value == 'suggested'
                                                    ? 'bg-amber-50 text-amber-700 ring-amber-200'
                                                    : 'bg-gray-100 text-gray-600 ring-gray-200') %}
                                            <li class="overflow-hidden rounded-lg border border-gray-200 border-l-4 border-l-{{ plannedColor }} bg-white shadow-xs">
                                                <div class="bg-{{ plannedColor }}/[.08] px-2 py-1.5">
                                                    <div class="flex items-start gap-2">
                                                        <a href="#" data-model-content-url="/planned-session?plannedSessionId={{ plannedSession.getId() }}" class="flex min-w-0 items-center gap-1 font-medium text-blue-600 hover:underline" title="{{ 'Edit planned session'|trans }}">
                                                            {{ svg('calendar', 'size-3') }}
                                                            <span class="truncate">{{ plannedTitle }}</span>
                                                        </a>
                                                    </div>
                                                    <div class="mt-1 flex flex-wrap items-center gap-x-1 gap-y-0.5 text-[10px] text-gray-500">
                                                        <span>{{ plannedSession.getActivityType()|trans }}</span>
                                                        <span>· {{ plannedSession.getLinkStatus().value|replace({'_': ' '})|title }}</span>
                                                    </div>
                                                </div>
                                                <div class="px-2 py-1.5">
                                                    <div class="flex flex-wrap gap-1 text-[10px] text-gray-600">
                                                        {% if plannedSession.getTargetDurationInSeconds() %}
                                                            <span class="rounded-full bg-gray-100 px-1.5 py-0.5 ring-1 ring-gray-200">{{ plannedSession.getTargetDurationInSeconds()|formatSecondsAsPaddedClock }}</span>
                                                        {% endif %}
                                                        {% if plannedEstimate is not null %}
                                                            <span class="rounded-full bg-gray-100 px-1.5 py-0.5 ring-1 ring-gray-200">{{ plannedEstimate|formatNumber(0) }} {{ "Load"|trans }}</span>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            </li>
                                        {% endfor %}
                                    </ul>
                                {% endif %}
                                {% if not day.getActivities().isEmpty() %}
                                    <ul class="space-y-1">
                                        {% for activity in day.getActivities() %}
                                            {% set color = activity.getSportType().getActivityType().getColor() %}
                                            <li class="truncate pl-1 bg-{{ color }}/[.1] border-l-2 border-l-{{ color }}">
                                                {{ activity|activityLink(truncate: true) }}
                                            </li>
                                        {% endfor %}
                                    </ul>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
            <aside class="rounded-xl border border-gray-200 bg-white p-4 shadow-xs">
                <div class="flex items-center justify-between gap-2">
                    <div>
                        <h4 class="text-sm font-semibold text-gray-900">{{ "Month planner"|trans }}</h4>
                        <p class="mt-1 text-xs text-gray-500">{{ "Review every planned session for this month in one place."|trans }}</p>
                    </div>
                    <a href="#" data-model-content-url="/planned-session?day={{ calendar.getMonth().getId() }}-01" class="inline-flex rounded-lg border border-gray-300 bg-white px-2.5 py-1.5 text-xs font-medium text-gray-700 hover:bg-gray-50">
                        {{ "Create session"|trans }}
                    </a>
                </div>
                <div class="mt-4 space-y-2 max-h-[32rem] overflow-y-auto pr-1">
                    {% if plannedSessionsForMonth is empty %}
                        <div class="rounded-lg border border-dashed border-gray-300 bg-white p-4 text-sm text-gray-500">
                            {{ "No planned sessions yet for this month."|trans }}
                        </div>
                    {% else %}
                        {% for plannedSession in plannedSessionsForMonth %}
                            {% set plannedEstimate = plannedSessionEstimatesById[plannedSession.getId() ~ ''] ?? null %}
                            {% set plannedColor = plannedSession.getActivityType().getColor() %}
                            {% set plannedTitle = plannedSession.getTitle() ?: (plannedSession.getActivityType()|trans) %}
                            {% set linkStatusClasses = plannedSession.getLinkStatus().value == 'linked'
                                ? 'bg-green-50 text-green-700 ring-green-200'
                                : (plannedSession.getLinkStatus().value == 'suggested'
                                    ? 'bg-amber-50 text-amber-700 ring-amber-200'
                                    : 'bg-gray-100 text-gray-600 ring-gray-200') %}
                            <div class="overflow-hidden rounded-xl border border-gray-200 border-l-4 border-l-{{ plannedColor }} bg-white shadow-xs transition-colors hover:border-gray-300">
                                <div class="bg-{{ plannedColor }}/[.08] px-3 py-2.5">
                                    <div class="flex items-start justify-between gap-3">
                                        <div class="min-w-0">
                                            <a href="#" data-model-content-url="/planned-session?plannedSessionId={{ plannedSession.getId() }}" class="flex items-center gap-2 text-sm font-medium text-blue-600 hover:underline" title="{{ 'Edit planned session'|trans }}">
                                                <span class="inline-flex size-7 shrink-0 items-center justify-center rounded-full bg-white ring-1 ring-gray-200">
                                                    {{ svg('calendar', 'size-3.5') }}
                                                </span>
                                                <span class="truncate">{{ plannedTitle }}</span>
                                            </a>
                                            <div class="mt-1 flex flex-wrap items-center gap-x-1 gap-y-0.5 text-xs text-gray-500">
                                                <span>{{ plannedSession.getDay().format('D d M') }}</span>
                                                <span>·</span>
                                                <span>{{ plannedSession.getActivityType()|trans }}</span>
                                            </div>
                                        </div>
                                        <span class="inline-flex shrink-0 rounded-full px-2 py-1 text-[10px] font-semibold uppercase ring-1 {{ linkStatusClasses }}">{{ plannedSession.getLinkStatus().value|replace({'_': ' '})|title }}</span>
                                    </div>
                                </div>
                                <div class="px-3 py-2.5">
                                    <div class="flex flex-wrap gap-1.5 text-[11px] text-gray-600">
                                        {% if plannedSession.getTargetDurationInSeconds() %}
                                            <span class="rounded-full bg-gray-100 px-2 py-1 ring-1 ring-gray-200">{{ plannedSession.getTargetDurationInSeconds()|formatSecondsAsPaddedClock }}</span>
                                        {% endif %}
                                        {% if plannedEstimate is not null %}
                                            <span class="rounded-full bg-gray-100 px-2 py-1 ring-1 ring-gray-200">{{ plannedEstimate|formatNumber(0) }} {{ "Load"|trans }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </aside>
        </div>
    </div>
{% endautoescape %}