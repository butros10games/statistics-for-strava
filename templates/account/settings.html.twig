{% autoescape false %}
    {% set garminModeLabel = garminConnectionMode == 'credentials'
        ? 'Email + password'|trans
        : (garminConnectionMode == 'browser-token'
            ? 'Browser token'|trans
            : (garminConnectionMode == 'device-token' ? 'Device token'|trans : 'Not configured'|trans))
    %}

    <div data-manual-sync-root>
        {# ── Page header ── #}
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between mb-4">
            <h3 class="text-lg font-semibold">{{ "Account settings"|trans }}</h3>
            <a href="/logout" class="inline-flex items-center gap-1.5 self-start rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-xs transition hover:bg-gray-50">
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9"/></svg>
                {{ "Sign out"|trans }}
            </a>
        </div>

        {# ── Account card ── #}
        <div class="grid grid-cols-1 gap-4 mb-4">
            <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs">
                <h3 class="text-lg font-semibold mb-4">{{ "Account"|trans }}</h3>
                <dl class="space-y-3 text-sm">
                    <div class="flex items-center justify-between gap-3">
                        <dt class="text-gray-500">{{ "Email"|trans }}</dt>
                        <dd class="text-right font-medium text-gray-900">{{ appUser.getEmail() }}</dd>
                    </div>
                    <div class="flex items-center justify-between gap-3">
                        <dt class="text-gray-500">{{ "Email verification"|trans }}</dt>
                        <dd class="text-right">
                            {% if appUser.isEmailVerified() %}
                                <span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700">
                                    <svg class="size-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                                    {{ "Verified"|trans }}
                                </span>
                            {% else %}
                                <span class="rounded-full bg-amber-100 px-2.5 py-1 text-xs font-semibold text-amber-700">{{ "Pending"|trans }}</span>
                                {% if appUser.getEmailVerificationToken() %}
                                    <a href="/verify-email/{{ appUser.getEmailVerificationToken() }}" class="ml-3 text-xs font-medium text-strava-orange hover:text-orange-600">{{ "Verify now"|trans }}</a>
                                {% endif %}
                            {% endif %}
                        </dd>
                    </div>
                </dl>
            </div>
        </div>

        {# ── Connections grid ── #}
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-4 mb-4">
            {# ── Strava connection ── #}
            <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs flex flex-col" data-manual-sync-card="strava">
                <div class="mb-4">
                    <div class="flex items-center gap-2">
                        <h3 class="text-lg font-semibold">{{ "Strava connection"|trans }}</h3>
                        {% if stravaConnection %}
                            <span class="inline-flex rounded-full bg-emerald-100 px-2 py-0.5 text-[11px] font-semibold text-emerald-700">{{ "Connected"|trans }}</span>
                        {% else %}
                            <span class="inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-[11px] font-semibold text-gray-600">{{ "Not connected"|trans }}</span>
                        {% endif %}
                    </div>
                    <p class="mt-1 text-xs text-gray-500">{{ "Connect your Strava account and trigger a manual refresh whenever you want."|trans }}</p>
                    <div class="flex flex-wrap gap-2 mt-3">
                        <a href="/strava-oauth" class="inline-flex items-center gap-1.5 rounded-lg bg-strava-orange px-3 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-orange-600">
                            <svg class="size-4" fill="currentColor" viewBox="0 0 24 24"><path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169"/></svg>
                            {{ stravaConnection ? 'Reconnect'|trans : 'Connect Strava'|trans }}
                        </a>
                        {% if stravaConnection %}
                            <form method="post" action="/account/strava/disconnect">
                                <button type="submit" class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-xs transition hover:bg-gray-50">{{ "Disconnect"|trans }}</button>
                            </form>
                        {% endif %}
                    </div>
                </div>

                {% if stravaConnection %}
                    <dl class="grid gap-3 text-sm sm:grid-cols-2 mb-4">
                        <div class="rounded-lg bg-gray-50 p-3">
                            <dt class="text-xs text-gray-500">{{ "Athlete ID"|trans }}</dt>
                            <dd class="mt-1 font-medium text-gray-900">{{ stravaConnection.getStravaAthleteId() }}</dd>
                        </div>
                        <div class="rounded-lg bg-gray-50 p-3">
                            <dt class="text-xs text-gray-500">{{ "Scopes"|trans }}</dt>
                            <dd class="mt-1 font-medium text-gray-900">{{ stravaConnection.getScopes()|join(', ') }}</dd>
                        </div>
                    </dl>
                {% else %}
                    <div class="flex items-center gap-3 rounded-lg border border-dashed border-gray-300 bg-gray-50 px-4 py-5 mb-4">
                        <svg class="size-5 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
                        <span class="text-sm text-gray-500">{{ "No Strava account is linked yet."|trans }}</span>
                    </div>
                {% endif %}

                <div class="mt-auto rounded-lg bg-gray-50 border border-gray-200 p-4">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <div>
                            <div class="text-sm font-medium text-gray-900">{{ "Manual Strava import"|trans }}</div>
                            <p class="mt-0.5 text-xs text-gray-500">{{ "Pull the latest Strava data and rebuild the app now."|trans }}</p>
                        </div>
                        <button
                            type="button"
                            data-manual-sync-button
                            data-manual-sync-provider="strava"
                            data-manual-sync-url="/account/sync/strava"
                            data-loading-text="{{ 'Syncing Strava…'|trans }}"
                            class="inline-flex items-center justify-center gap-2 rounded-lg bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-gray-800 disabled:cursor-not-allowed disabled:bg-gray-300"
                            {{ not stravaConnection ? 'disabled' : '' }}
                        >
                            <svg class="hidden size-4 animate-spin" data-manual-sync-spinner viewBox="0 0 24 24" fill="none">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-90" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                            </svg>
                            <span data-manual-sync-label>{{ "Sync Strava now"|trans }}</span>
                        </button>
                    </div>
                    <div class="mt-3 hidden overflow-hidden rounded-full bg-orange-100" data-manual-sync-progress>
                        <div class="h-1.5 w-full animate-pulse bg-strava-orange"></div>
                    </div>
                    <p class="mt-3 hidden text-sm" data-manual-sync-status></p>
                    <pre class="mt-3 hidden max-h-56 overflow-auto rounded-lg bg-gray-950 px-4 py-3 text-xs text-gray-100" data-manual-sync-output></pre>
                </div>
            </div>

            {# ── Garmin wellness ── #}
            <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs flex flex-col" data-manual-sync-card="garmin">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between mb-4">
                    <div>
                        <div class="flex items-center gap-2">
                            <h3 class="text-lg font-semibold">{{ "Garmin wellness"|trans }}</h3>
                            {% if garminEnabled and garminConfigured %}
                                <span class="inline-flex rounded-full bg-emerald-100 px-2 py-0.5 text-[11px] font-semibold text-emerald-700">{{ "Connected"|trans }}</span>
                            {% elseif garminEnabled %}
                                <span class="inline-flex rounded-full bg-amber-100 px-2 py-0.5 text-[11px] font-semibold text-amber-700">{{ "Needs setup"|trans }}</span>
                            {% else %}
                                <span class="inline-flex rounded-full bg-gray-100 px-2 py-0.5 text-[11px] font-semibold text-gray-600">{{ "Disabled"|trans }}</span>
                            {% endif %}
                        </div>
                        <p class="mt-1 text-xs text-gray-500">{{ "Garmin sync uses the wellness bridge configuration from your app environment and config files."|trans }}</p>
                    </div>
                </div>

                <dl class="grid gap-3 text-sm sm:grid-cols-2 mb-4">
                    <div class="rounded-lg bg-gray-50 p-3">
                        <dt class="text-xs text-gray-500">{{ "Connection mode"|trans }}</dt>
                        <dd class="mt-1 font-medium text-gray-900">{{ garminModeLabel }}</dd>
                    </div>
                    <div class="rounded-lg bg-gray-50 p-3">
                        <dt class="text-xs text-gray-500">{{ "Wellness import"|trans }}</dt>
                        <dd class="mt-1 font-medium text-gray-900">{{ garminEnabled ? 'Enabled'|trans : 'Disabled'|trans }}</dd>
                    </div>
                    <div class="rounded-lg bg-gray-50 p-3">
                        <dt class="text-xs text-gray-500">{{ "Bridge source file"|trans }}</dt>
                        <dd class="mt-1 break-all font-medium text-gray-900">{{ garminBridgeSourcePath }}</dd>
                    </div>
                    <div class="rounded-lg bg-gray-50 p-3">
                        <dt class="text-xs text-gray-500">{{ "Last imported Garmin day"|trans }}</dt>
                        <dd class="mt-1 font-medium text-gray-900" data-garmin-last-import>{{ garminLastImportedDay ? garminLastImportedDay.format('Y-m-d') : 'No Garmin wellness days imported yet.'|trans }}</dd>
                    </div>
                </dl>

                {% if not garminEnabled %}
                    <div class="rounded-lg border border-dashed border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-800 mb-4">
                        {{ "Enable integrations.wellness.enabled in your app config before Garmin sync can run."|trans }}
                    </div>
                {% elseif not garminConfigured %}
                    <div class="rounded-lg border border-dashed border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-800 mb-4">
                        {{ "Add Garmin credentials or tokens to your environment before using the manual Garmin sync."|trans }}
                    </div>
                {% endif %}

                <div class="mt-auto rounded-lg bg-gray-50 border border-gray-200 p-4">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <div>
                            <div class="text-sm font-medium text-gray-900">{{ "Manual Garmin import"|trans }}</div>
                            <p class="mt-0.5 text-xs text-gray-500">{{ "Refresh Garmin wellness bridge data, import it, and rebuild the app now."|trans }}</p>
                        </div>
                        <button
                            type="button"
                            data-manual-sync-button
                            data-manual-sync-provider="garmin"
                            data-manual-sync-url="/account/sync/garmin"
                            data-loading-text="{{ 'Syncing Garmin…'|trans }}"
                            class="inline-flex items-center justify-center gap-2 rounded-lg bg-gray-900 px-3 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-gray-800 disabled:cursor-not-allowed disabled:bg-gray-300"
                            {{ not garminCanSync ? 'disabled' : '' }}
                        >
                            <svg class="hidden size-4 animate-spin" data-manual-sync-spinner viewBox="0 0 24 24" fill="none">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-90" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"></path>
                            </svg>
                            <span data-manual-sync-label>{{ "Sync Garmin now"|trans }}</span>
                        </button>
                    </div>
                    <div class="mt-3 hidden overflow-hidden rounded-full bg-orange-100" data-manual-sync-progress>
                        <div class="h-1.5 w-full animate-pulse bg-strava-orange"></div>
                    </div>
                    <p class="mt-3 hidden text-sm" data-manual-sync-status></p>
                    <pre class="mt-3 hidden max-h-56 overflow-auto rounded-lg bg-gray-950 px-4 py-3 text-xs text-gray-100" data-manual-sync-output></pre>
                </div>
            </div>
        </div>
    </div>
{% endautoescape %}
