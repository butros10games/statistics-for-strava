{% extends 'auth/_auth-shell.html.twig' %}

{% block auth_body %}
    <div class="space-y-6">
        <div class="text-center">
            <h2 class="text-2xl font-bold text-gray-900">{{ "Reset password"|trans }}</h2>
            <p class="mt-1 text-sm text-gray-500">{{ "Enter your email and we'll create a reset link for you"|trans }}</p>
        </div>

        {% if submitted|default(false) %}
            <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
                If that account exists, a reset link is ready.
                {% if resetLink %}
                    <div class="mt-2 break-all"><a class="font-medium underline" href="{{ resetLink }}">{{ app.request.getSchemeAndHttpHost() ~ resetLink }}</a></div>
                {% endif %}
            </div>
        {% endif %}

        <form method="post" action="/reset-password" class="space-y-4">
            <div>
                <label class="mb-1 block text-sm font-medium text-gray-700" for="email">Email</label>
                <input id="email" name="email" type="email" required autocomplete="email" class="block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm shadow-sm focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-200">
            </div>
            <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-strava-orange px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2">{{ "Create reset link"|trans }}</button>
        </form>

        <div class="text-center text-sm text-gray-500">
            <a href="/login" class="font-medium text-strava-orange hover:text-orange-600">{{ "Back to sign in"|trans }}</a>
        </div>
    </div>
{% endblock %}
