{% extends 'auth/_auth-shell.html.twig' %}

{% block auth_body %}
    <div class="space-y-6">
        <div class="text-center">
            <h2 class="text-2xl font-bold text-gray-900">{{ "Create your account"|trans }}</h2>
            <p class="mt-1 text-sm text-gray-500">{{ "Get started with your training data"|trans }}</p>
        </div>

        {% if error is defined and error %}
            <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">{{ error }}</div>
        {% endif %}

        <form method="post" action="/register" class="space-y-4">
            <div>
                <label class="mb-1 block text-sm font-medium text-gray-700" for="email">Email</label>
                <input id="email" name="email" type="email" value="{{ email|default('') }}" required autocomplete="email" class="block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm shadow-sm focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-200">
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-gray-700" for="password">Password</label>
                <input id="password" name="password" type="password" required autocomplete="new-password" class="block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm shadow-sm focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-200">
            </div>
            <div>
                <label class="mb-1 block text-sm font-medium text-gray-700" for="passwordConfirmation">Confirm password</label>
                <input id="passwordConfirmation" name="passwordConfirmation" type="password" required autocomplete="new-password" class="block w-full rounded-xl border border-gray-300 px-4 py-3 text-sm shadow-sm focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-200">
            </div>
            <button type="submit" class="inline-flex w-full items-center justify-center rounded-xl bg-strava-orange px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-orange-600 focus:outline-none focus:ring-2 focus:ring-orange-500 focus:ring-offset-2">{{ "Create account"|trans }}</button>
        </form>

        <div class="text-center text-sm text-gray-500">
            {{ "Already have an account?"|trans }}
            <a href="/login" class="font-medium text-strava-orange hover:text-orange-600">{{ "Sign in"|trans }}</a>
        </div>
    </div>
{% endblock %}
